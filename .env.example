# ── Telegram ──────────────────────
BOT_TOKEN=your_bot_token_here

# ── PostgreSQL (Railway auto-fills DATABASE_URL) ──
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── AI Providers ──────────────────
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

CERBER_API_KEY=your_cerber_key
CERBER_API_URL=https://api.cerberai.com/v1
CERBER_MODEL=cerberus-xl

DEFAULT_AI_PROVIDER=groq   # groq | cerber

# ── Admins (через запятую) ────────
ADMIN_IDS=123456789,987654321

# ── Поведение ─────────────────────
MAX_HISTORY=20
MAFIA_MIN_PLAYERS=4
MAFIA_MAX_PLAYERS=10
# true = бот отвечает на ВСЕ сообщения в группах (без упоминания)
GROUP_AI_ALL=false
